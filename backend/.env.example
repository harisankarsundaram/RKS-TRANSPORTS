# Environment Variables
# PostgreSQL Database Connection (NeonDB)
DATABASE_URL=postgres://user:password@endpoint.neon.tech/neondb?sslmode=require

# Server Configuration
PORT=3000

# Tracking route precision (OpenRouteService key is optional but improves road-following path + ETA)
GPS_ROUTE_ENGINE=auto
OPENROUTESERVICE_API_KEY=
BACKEND_TRACKING_HISTORY_ROUTE_MAX_WAYPOINTS=48

# JWT Secret (add this for production)
# JWT_SECRET=your_secret_key_here
