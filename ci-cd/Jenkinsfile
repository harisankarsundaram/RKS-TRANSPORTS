pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    triggers {
        githubPush()
    }

    environment {
        IMAGE_REGISTRY = 'docker.io/harisankarsundaram'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
        K8S_NAMESPACE = 'rks-logistics'
        DOCKER_CREDENTIALS_ID = 'dockerhub-creds'
        EFFECTIVE_BRANCH = "${env.BRANCH_NAME ?: 'devops'}"
        KUBECONFIG = "${env.WORKSPACE}/.jenkins-kubeconfig"
        KUBE_FALLBACK_MARKER = "${env.WORKSPACE}/.kube-via-rks"
        RKS_KUBECTL_PATH_FILE = "${env.WORKSPACE}/.rks-kubectl-path"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Validate Toolchain') {
            steps {
                sh '''
                    set -e
                    echo "Validating required tools on Jenkins agent"
                    command -v docker >/dev/null
                    command -v python3 >/dev/null
                    command -v npm >/dev/null
                '''
            }
        }

        stage('Validate Parameters') {
            steps {
                script {
                    if (env.EFFECTIVE_BRANCH == 'devops') {
                        echo 'Default behavior enabled: Docker push and Kubernetes deploy will run for devops branch.'
                    }
                }
            }
        }

        stage('Build') {
            steps {
                sh '''
                    set -e
                    echo "Installing dependencies..."

                    for dir in \
                      services/api-gateway \
                      services/auth-service \
                      services/fleet-service \
                      services/trip-service \
                      services/booking-service \
                      services/tracking-service \
                      services/mock-gps-service \
                      services/analytics-service \
                      services/alert-service \
                      services/optimization-service \
                      frontend; do
                      if [ -f "$dir/package.json" ]; then
                                                echo "Installing npm dependencies in $dir"
                                                if [ -f "$dir/package-lock.json" ]; then
                                                    (cd "$dir" && npm ci)
                                                else
                                                    (cd "$dir" && npm install)
                                                fi
                      fi
                    done

                                        echo "Installing Python dependencies..."
                                        python3 -m pip install --break-system-packages -r services/ml-service/requirements.txt

                                        echo "Validating Docker Compose..."
                                        compose_cmd=""
                                        if docker compose version >/dev/null 2>&1; then
                                            compose_cmd="docker compose"
                                        elif command -v docker-compose >/dev/null 2>&1; then
                                            compose_cmd="docker-compose"
                                        fi

                                        if [ -n "$compose_cmd" ]; then
                                            if [ -f docker/.env ]; then
                                                $compose_cmd -f docker/docker-compose.yml --env-file docker/.env config > /dev/null
                                            else
                                                $compose_cmd -f docker/docker-compose.yml --env-file docker/.env.example config > /dev/null
                                            fi
                                        else
                                            echo "Docker Compose CLI not available on Jenkins agent. Skipping compose validation."
                                        fi
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                    set -e
                    echo " Running tests..."

                    for dir in \
                      services/api-gateway \
                      services/auth-service \
                      services/fleet-service \
                      services/trip-service \
                      services/booking-service \
                      services/tracking-service \
                      services/mock-gps-service \
                      services/analytics-service \
                      services/alert-service \
                      services/optimization-service \
                      frontend; do
                      if [ -f "$dir/package.json" ]; then
                        if npm --prefix "$dir" run | grep -qE ' test'; then
                          echo "Running tests in $dir"
                          npm --prefix "$dir" test -- --ci
                        else
                          echo "No test script in $dir, skipping"
                        fi
                      fi
                    done

                    echo "Checking Python syntax..."
                    python3 -m compileall services/ml-service/app
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                    echo "Building Docker images..."
                    bash scripts/build-images.sh "$IMAGE_REGISTRY" "$IMAGE_TAG"
                '''
            }
        }

        stage('Docker Push') {
            when {
                expression {
                    return env.EFFECTIVE_BRANCH == 'devops'
                }
            }
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: "${env.DOCKER_CREDENTIALS_ID}",
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {
                    script {
                        int pushStatus = sh(
                            returnStatus: true,
                            script: '''
                                set +e
                                echo "Logging into Docker registry..."
                                echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                                login_rc=$?

                                if [ "$login_rc" -ne 0 ]; then
                                    echo "Docker registry login failed."
                                    exit 42
                                fi

                                echo "Pushing images..."
                                bash scripts/push-images.sh "$IMAGE_REGISTRY" "$IMAGE_TAG"
                                push_rc=$?

                                docker logout || true

                                if [ "$push_rc" -ne 0 ]; then
                                    echo "Docker push failed."
                                    exit 43
                                fi

                                exit 0
                            '''
                        )

                        if (pushStatus == 42 || pushStatus == 43) {
                            echo 'Docker Hub unavailable or push failed. Falling back to local Minikube image load.'
                            sh '''
                                set -e
                                bash scripts/load-images-into-minikube.sh "$IMAGE_REGISTRY" "$IMAGE_TAG" rks
                            '''
                        } else if (pushStatus == 0) {
                            sh '''
                                set -e
                                echo "Loading pushed images into Minikube for imagePullPolicy: Never deployments..."
                                bash scripts/load-images-into-minikube.sh "$IMAGE_REGISTRY" "$IMAGE_TAG" rks
                            '''
                        } else if (pushStatus != 0) {
                            error("Docker push failed with status ${pushStatus}")
                        }
                    }
                }
            }
        }

        stage('Apply Kubernetes Secret') {
            when {
                expression {
                    return env.EFFECTIVE_BRANCH == 'devops'
                }
            }
            steps {
                sh '''
                    set -e
                    echo "Preparing Kubernetes access for Jenkins container..."
                    rm -f "$KUBE_FALLBACK_MARKER"
                    rm -f "$RKS_KUBECTL_PATH_FILE"

                                        if ! docker inspect rks >/dev/null 2>&1; then
                                            echo "Minikube Docker container 'rks' not found."
                                            exit 1
                                        fi

                                        if [ "$(docker inspect -f '{{.State.Running}}' rks 2>/dev/null || echo false)" != "true" ]; then
                                            echo "Minikube container 'rks' is stopped. Starting it..."
                                            docker start rks >/dev/null
                                            sleep 8
                                        fi

                                        if [ "$(docker exec rks systemctl is-active kubelet 2>/dev/null || true)" != "active" ]; then
                                            echo "kubelet is not active in 'rks'. Starting kubelet..."
                                            docker exec rks systemctl start kubelet >/dev/null
                                            sleep 10
                                        fi

                    if [ ! -f /root/.kube/config ]; then
                      echo "Missing /root/.kube/config in Jenkins container"
                      exit 1
                    fi

                    cp /root/.kube/config "$KUBECONFIG"

                    # Convert Windows-style kubeconfig paths to Linux paths used inside container.
                    sed -i 's#C:\\\\Users\\\\[^\\\\]*\\\\.minikube#/root/.minikube#g' "$KUBECONFIG"
                    sed -i 's#\\\\#/#g' "$KUBECONFIG"

                    # Minikube on Windows often exposes API server on localhost; inside container use host.docker.internal.
                    sed -i 's#https://127.0.0.1:#https://host.docker.internal:#g' "$KUBECONFIG"
                    sed -i 's#https://localhost:#https://host.docker.internal:#g' "$KUBECONFIG"

                                        # If host.docker.internal endpoint is not reachable from Jenkins container,
                                        # switch to Minikube container IP:8443 and skip TLS verification for local-dev CI.
                                        if ! kubectl --request-timeout=5s get --raw='/readyz' >/dev/null 2>&1; then
                                            echo "Primary Kubernetes endpoint not reachable; trying Minikube container endpoint..."

                                            # Docker may expose address in either .IPAddress or .IPAMConfig.IPv4Address.
                                            raw_ips="$(docker inspect rks --format '{{range $name, $net := .NetworkSettings.Networks}}{{if $net.IPAddress}}{{$net.IPAddress}} {{end}}{{if $net.IPAMConfig}}{{$net.IPAMConfig.IPv4Address}} {{end}}{{end}}' 2>/dev/null || true)"
                                              minikube_ip="$(echo "$raw_ips" | tr ' ' '\n' | grep -E '^[0-9]+[.][0-9]+[.][0-9]+[.][0-9]+$' | head -n 1 || true)"

                                            if [ -z "$minikube_ip" ]; then
                                                echo "Could not resolve valid Minikube container IPv4 for 'rks'. Raw values: '$raw_ips'"
                                                exit 1
                                            fi

                                            current_context="$(kubectl config current-context)"
                                            cluster_name="$(kubectl config view -o jsonpath="{.contexts[?(@.name=='$current_context')].context.cluster}")"
                                            if [ -z "$cluster_name" ]; then
                                                echo "Could not resolve cluster name from current context: $current_context"
                                                exit 1
                                            fi

                                            kubectl config set-cluster "$cluster_name" --server="https://$minikube_ip:8443" --insecure-skip-tls-verify=true >/dev/null

                                            # Some environments isolate Jenkins on a different Docker network.
                                            # If Minikube IP still isn't reachable, connect Jenkins to Minikube's actual network and use DNS name.
                                            if ! kubectl --request-timeout=5s get --raw='/readyz' >/dev/null 2>&1; then
                                                minikube_network="$(docker inspect rks --format '{{range $name, $net := .NetworkSettings.Networks}}{{$name}} {{end}}' 2>/dev/null | awk '{print $1}')"
                                                echo "Minikube IP endpoint still unreachable; trying Docker network bridge via '${minikube_network}'..."
                                                if [ -n "$minikube_network" ] && docker network inspect "$minikube_network" >/dev/null 2>&1; then
                                                    docker network connect "$minikube_network" "$HOSTNAME" >/dev/null 2>&1 || true
                                                    kubectl config set-cluster "$cluster_name" --server="https://rks:8443" --insecure-skip-tls-verify=true >/dev/null
                                                else
                                                    echo "Could not determine Minikube Docker network from container 'rks'."
                                                fi
                                            fi

                                            if ! kubectl --request-timeout=10s get --raw='/readyz' >/dev/null 2>&1; then
                                                echo "Kubernetes API is still unreachable after endpoint fallbacks. Trying in-container kubectl mode..."
                                                rks_kubectl="$(docker exec rks sh -lc 'command -v kubectl 2>/dev/null || find /var/lib/minikube/binaries -maxdepth 4 -type f -name kubectl 2>/dev/null | head -n 1' | tr -d '\r')"
                                                if [ -z "$rks_kubectl" ]; then
                                                    echo "Could not locate kubectl binary inside 'rks' container."
                                                    exit 1
                                                fi

                                                if docker exec rks "$rks_kubectl" --kubeconfig /var/lib/minikube/kubeconfig --request-timeout=10s get --raw=/readyz >/dev/null 2>&1; then
                                                    echo "Using in-container kubectl mode via 'docker exec rks kubectl'."
                                                    touch "$KUBE_FALLBACK_MARKER"
                                                    echo "$rks_kubectl" > "$RKS_KUBECTL_PATH_FILE"
                                                else
                                                    echo "In-container kubectl mode also failed."
                                                    kubectl config view --minify
                                                    exit 1
                                                fi
                                            fi
                                        fi

                    kubectl config get-contexts >/dev/null
                '''
                sh '''
                    set -e
                    echo "Applying Kubernetes secret manifest..."
                    secret_manifest="k8s/secret.yaml"
                    if [ ! -f "$secret_manifest" ]; then
                      echo "k8s/secret.yaml not found. Falling back to k8s/secret.example.yaml"
                      secret_manifest="k8s/secret.example.yaml"
                    fi

                                        if [ -f "$KUBE_FALLBACK_MARKER" ]; then
                                            echo "Applying secret via in-container kubectl mode"
                                            rks_kubectl="$(cat "$RKS_KUBECTL_PATH_FILE" 2>/dev/null || true)"
                                            if [ -z "$rks_kubectl" ]; then
                                                rks_kubectl="$(docker exec rks sh -lc 'command -v kubectl 2>/dev/null || find /var/lib/minikube/binaries -maxdepth 4 -type f -name kubectl 2>/dev/null | head -n 1' | tr -d '\r')"
                                            fi
                                            cat "$secret_manifest" | docker exec -i rks "$rks_kubectl" --kubeconfig /var/lib/minikube/kubeconfig apply --validate=false -f -
                                        else
                                            kubectl apply --validate=false -f "$secret_manifest"
                                        fi
                '''
            }
        }

        stage('Kubernetes Deploy') {
            when {
                expression {
                    return env.EFFECTIVE_BRANCH == 'devops'
                }
            }
            steps {
                sh '''
                    echo "Deploying to Kubernetes..."
                                        if [ -f "$KUBE_FALLBACK_MARKER" ]; then
                                            echo "Deploying via in-container kubectl mode"
                                            rks_kubectl="$(cat "$RKS_KUBECTL_PATH_FILE" 2>/dev/null || true)"
                                            if [ -z "$rks_kubectl" ]; then
                                                rks_kubectl="$(docker exec rks sh -lc 'command -v kubectl 2>/dev/null || find /var/lib/minikube/binaries -maxdepth 4 -type f -name kubectl 2>/dev/null | head -n 1' | tr -d '\r')"
                                            fi
                                            docker cp k8s/. rks:/tmp/rks-k8s
                                            docker exec rks "$rks_kubectl" --kubeconfig /var/lib/minikube/kubeconfig apply -k /tmp/rks-k8s

                                            for spec in \
                                                "deployment/api-gateway api-gateway=${IMAGE_REGISTRY}/rks-api-gateway:${IMAGE_TAG}" \
                                                "deployment/auth-service auth-service=${IMAGE_REGISTRY}/rks-auth-service:${IMAGE_TAG}" \
                                                "deployment/fleet-service fleet-service=${IMAGE_REGISTRY}/rks-fleet-service:${IMAGE_TAG}" \
                                                "deployment/trip-service trip-service=${IMAGE_REGISTRY}/rks-trip-service:${IMAGE_TAG}" \
                                                "deployment/booking-service booking-service=${IMAGE_REGISTRY}/rks-booking-service:${IMAGE_TAG}" \
                                                "deployment/tracking-service tracking-service=${IMAGE_REGISTRY}/rks-tracking-service:${IMAGE_TAG}" \
                                                "deployment/mock-gps-service mock-gps-service=${IMAGE_REGISTRY}/rks-mock-gps-service:${IMAGE_TAG}" \
                                                "deployment/analytics-service analytics-service=${IMAGE_REGISTRY}/rks-analytics-service:${IMAGE_TAG}" \
                                                "deployment/alert-service alert-service=${IMAGE_REGISTRY}/rks-alert-service:${IMAGE_TAG}" \
                                                "deployment/optimization-service optimization-service=${IMAGE_REGISTRY}/rks-optimization-service:${IMAGE_TAG}" \
                                                "deployment/ml-service ml-service=${IMAGE_REGISTRY}/rks-ml-service:${IMAGE_TAG}" \
                                                "deployment/rks-frontend frontend=${IMAGE_REGISTRY}/rks-frontend:${IMAGE_TAG}"; do
                                                docker exec rks "$rks_kubectl" --kubeconfig /var/lib/minikube/kubeconfig -n "$K8S_NAMESPACE" set image $spec
                                            done

                                            for deployment in \
                                                api-gateway \
                                                auth-service \
                                                fleet-service \
                                                trip-service \
                                                booking-service \
                                                tracking-service \
                                                mock-gps-service \
                                                analytics-service \
                                                alert-service \
                                                optimization-service \
                                                ml-service \
                                                rks-frontend \
                                                prometheus \
                                                blackbox-exporter \
                                                grafana; do
                                                docker exec rks "$rks_kubectl" --kubeconfig /var/lib/minikube/kubeconfig -n "$K8S_NAMESPACE" rollout status "deployment/${deployment}" --timeout=600s
                                            done
                                        else
                                            bash scripts/deploy-k8s.sh "$IMAGE_REGISTRY" "$IMAGE_TAG" "$K8S_NAMESPACE"
                                        fi
                '''
            }
        }

        stage('Verify Monitoring') {
            when {
                expression {
                    return env.EFFECTIVE_BRANCH == 'devops'
                }
            }
            steps {
                sh '''
                    set -e
                    echo "Checking monitoring resources"
                                        if [ -f "$KUBE_FALLBACK_MARKER" ]; then
                                            rks_kubectl="$(cat "$RKS_KUBECTL_PATH_FILE" 2>/dev/null || true)"
                                            if [ -z "$rks_kubectl" ]; then
                                                rks_kubectl="$(docker exec rks sh -lc 'command -v kubectl 2>/dev/null || find /var/lib/minikube/binaries -maxdepth 4 -type f -name kubectl 2>/dev/null | head -n 1' | tr -d '\r')"
                                            fi
                                            docker exec rks "$rks_kubectl" --kubeconfig /var/lib/minikube/kubeconfig -n "$K8S_NAMESPACE" get deploy prometheus grafana blackbox-exporter
                                            docker exec rks "$rks_kubectl" --kubeconfig /var/lib/minikube/kubeconfig -n "$K8S_NAMESPACE" get svc prometheus grafana blackbox-exporter
                                        else
                                            kubectl -n "$K8S_NAMESPACE" get deploy prometheus grafana blackbox-exporter
                                            kubectl -n "$K8S_NAMESPACE" get svc prometheus grafana blackbox-exporter
                                        fi
                '''
            }
        }
    }

    post {
        always {
            echo "Archiving artifacts..."
            archiveArtifacts artifacts: 'k8s/**/*.yaml,docker/docker-compose.yml,ci-cd/Jenkinsfile', allowEmptyArchive: true
        }
        success {
            echo "Pipeline completed successfully for branch: ${env.EFFECTIVE_BRANCH}"
        }
        failure {
            echo "Pipeline failed. Check stage logs for details."
        }
    }
}

