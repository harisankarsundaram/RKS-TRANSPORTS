pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    triggers {
        githubPush()
    }

    environment {
        IMAGE_REGISTRY = 'docker.io/harisankarsundaram'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
        K8S_NAMESPACE = 'rks-logistics'
        DOCKER_CREDENTIALS_ID = 'dockerhub-creds'
        EFFECTIVE_BRANCH = "${env.BRANCH_NAME ?: 'devops'}"
        KUBECONFIG = "${env.WORKSPACE}/.jenkins-kubeconfig"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Validate Toolchain') {
            steps {
                sh '''
                    set -e
                    echo "Validating required tools on Jenkins agent"
                    command -v docker >/dev/null
                    command -v python3 >/dev/null
                    command -v npm >/dev/null
                '''
            }
        }

        stage('Validate Parameters') {
            steps {
                script {
                    if (env.EFFECTIVE_BRANCH == 'devops') {
                        echo 'Default behavior enabled: Docker push and Kubernetes deploy will run for devops branch.'
                    }
                }
            }
        }

        stage('Build') {
            steps {
                sh '''
                    set -e
                    echo "Installing dependencies..."

                    for dir in \
                      services/api-gateway \
                      services/auth-service \
                      services/fleet-service \
                      services/trip-service \
                      services/booking-service \
                      services/tracking-service \
                      services/mock-gps-service \
                      services/analytics-service \
                      services/alert-service \
                      services/optimization-service \
                      frontend; do
                      if [ -f "$dir/package.json" ]; then
                                                echo "Installing npm dependencies in $dir"
                                                if [ -f "$dir/package-lock.json" ]; then
                                                    (cd "$dir" && npm ci)
                                                else
                                                    (cd "$dir" && npm install)
                                                fi
                      fi
                    done

                                        echo "Installing Python dependencies..."
                                        python3 -m pip install --break-system-packages -r services/ml-service/requirements.txt

                                        echo "Validating Docker Compose..."
                                        compose_cmd=""
                                        if docker compose version >/dev/null 2>&1; then
                                            compose_cmd="docker compose"
                                        elif command -v docker-compose >/dev/null 2>&1; then
                                            compose_cmd="docker-compose"
                                        fi

                                        if [ -n "$compose_cmd" ]; then
                                            if [ -f docker/.env ]; then
                                                $compose_cmd -f docker/docker-compose.yml --env-file docker/.env config > /dev/null
                                            else
                                                $compose_cmd -f docker/docker-compose.yml --env-file docker/.env.example config > /dev/null
                                            fi
                                        else
                                            echo "Docker Compose CLI not available on Jenkins agent. Skipping compose validation."
                                        fi
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                    set -e
                    echo " Running tests..."

                    for dir in \
                      services/api-gateway \
                      services/auth-service \
                      services/fleet-service \
                      services/trip-service \
                      services/booking-service \
                      services/tracking-service \
                      services/mock-gps-service \
                      services/analytics-service \
                      services/alert-service \
                      services/optimization-service \
                      frontend; do
                      if [ -f "$dir/package.json" ]; then
                        if npm --prefix "$dir" run | grep -qE ' test'; then
                          echo "Running tests in $dir"
                          npm --prefix "$dir" test -- --ci
                        else
                          echo "No test script in $dir, skipping"
                        fi
                      fi
                    done

                    echo "Checking Python syntax..."
                    python3 -m compileall services/ml-service/app
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                    echo "Building Docker images..."
                    bash scripts/build-images.sh "$IMAGE_REGISTRY" "$IMAGE_TAG"
                '''
            }
        }

        stage('Docker Push') {
            when {
                expression {
                    return env.EFFECTIVE_BRANCH == 'devops'
                }
            }
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: "${env.DOCKER_CREDENTIALS_ID}",
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {
                    sh '''
                        set -e
                        echo "Logging into Docker registry..."
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin

                        echo "Pushing images..."
                        bash scripts/push-images.sh "$IMAGE_REGISTRY" "$IMAGE_TAG"

                        docker logout
                    '''
                }
            }
        }

        stage('Apply Kubernetes Secret') {
            when {
                expression {
                    return env.EFFECTIVE_BRANCH == 'devops'
                }
            }
            steps {
                sh '''
                    set -e
                    echo "Preparing Kubernetes access for Jenkins container..."
                    if [ ! -f /root/.kube/config ]; then
                      echo "Missing /root/.kube/config in Jenkins container"
                      exit 1
                    fi

                    cp /root/.kube/config "$KUBECONFIG"

                    # Convert Windows-style kubeconfig paths to Linux paths used inside container.
                    sed -i 's#C:\\\\Users\\\\[^\\\\]*\\\\.minikube#/root/.minikube#g' "$KUBECONFIG"
                    sed -i 's#\\\\#/#g' "$KUBECONFIG"

                    # Minikube on Windows often exposes API server on localhost; inside container use host.docker.internal.
                    sed -i 's#https://127.0.0.1:#https://host.docker.internal:#g' "$KUBECONFIG"
                    sed -i 's#https://localhost:#https://host.docker.internal:#g' "$KUBECONFIG"

                                        # If host.docker.internal endpoint is not reachable from Jenkins container,
                                        # switch to Minikube container IP:8443 and skip TLS verification for local-dev CI.
                                        if ! kubectl --request-timeout=5s get --raw='/readyz' >/dev/null 2>&1; then
                                            echo "Primary Kubernetes endpoint not reachable; trying Minikube container endpoint..."

                                            # Docker may expose address in either .IPAddress or .IPAMConfig.IPv4Address.
                                            raw_ips="$(docker inspect rks --format '{{range $name, $net := .NetworkSettings.Networks}}{{if $net.IPAddress}}{{$net.IPAddress}} {{end}}{{if $net.IPAMConfig}}{{$net.IPAMConfig.IPv4Address}} {{end}}{{end}}' 2>/dev/null || true)"
                                            minikube_ip="$(echo "$raw_ips" | tr ' ' '\n' | grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$' | head -n 1 || true)"

                                            if [ -z "$minikube_ip" ]; then
                                                echo "Could not resolve valid Minikube container IPv4 for 'rks'. Raw values: '$raw_ips'"
                                                exit 1
                                            fi

                                            current_context="$(kubectl config current-context)"
                                            cluster_name="$(kubectl config view -o jsonpath="{.contexts[?(@.name=='$current_context')].context.cluster}")"
                                            if [ -z "$cluster_name" ]; then
                                                echo "Could not resolve cluster name from current context: $current_context"
                                                exit 1
                                            fi

                                            kubectl config set-cluster "$cluster_name" --server="https://$minikube_ip:8443" --insecure-skip-tls-verify=true >/dev/null
                                        fi

                    kubectl config get-contexts >/dev/null
                '''
                sh '''
                    set -e
                    echo "Applying Kubernetes secret manifest..."
                    secret_manifest="k8s/secret.yaml"
                    if [ ! -f "$secret_manifest" ]; then
                      echo "k8s/secret.yaml not found. Falling back to k8s/secret.example.yaml"
                      secret_manifest="k8s/secret.example.yaml"
                    fi
                                        kubectl apply --validate=false -f "$secret_manifest"
                '''
            }
        }

        stage('Kubernetes Deploy') {
            when {
                expression {
                    return env.EFFECTIVE_BRANCH == 'devops'
                }
            }
            steps {
                sh '''
                    echo "Deploying to Kubernetes..."
                    bash scripts/deploy-k8s.sh "$IMAGE_REGISTRY" "$IMAGE_TAG" "$K8S_NAMESPACE"
                '''
            }
        }

        stage('Verify Monitoring') {
            when {
                expression {
                    return env.EFFECTIVE_BRANCH == 'devops'
                }
            }
            steps {
                sh '''
                    set -e
                    echo "Checking monitoring resources"
                    kubectl -n "$K8S_NAMESPACE" get deploy prometheus grafana blackbox-exporter
                    kubectl -n "$K8S_NAMESPACE" get svc prometheus grafana blackbox-exporter
                '''
            }
        }
    }

    post {
        always {
            echo "Archiving artifacts..."
            archiveArtifacts artifacts: 'k8s/**/*.yaml,docker/docker-compose.yml,ci-cd/Jenkinsfile', allowEmptyArchive: true
        }
        success {
            echo "Pipeline completed successfully for branch: ${env.EFFECTIVE_BRANCH}"
        }
        failure {
            echo "Pipeline failed. Check stage logs for details."
        }
    }
}
