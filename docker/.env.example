# Cloud PostgreSQL connection string (Supabase/Neon/etc)
DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:6543/postgres
JWT_SECRET=change_this_secret

MOCK_GPS_TICK_MS=5000
GPS_ROUTE_PROVIDER=auto
GPS_ROUTE_ENGINE=openrouteservice
OPENROUTESERVICE_API_KEY=

ANALYTICS_INTERVAL_MS=120000
OPTIMIZATION_INTERVAL_MS=120000
