{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run backend stack",
			"type": "shell",
			"command": "docker",
			"args": [
				"compose",
				"--parallel",
				"1",
				"-f",
				"docker/docker-compose.yml",
				"--env-file",
				"docker/.env",
				"up",
				"-d",
				"--build"
			],
			"isBackground": false,
			"group": "build",
			"options": {
				"env": {
					"BUILDX_NO_DEFAULT_ATTESTATIONS": "1"
				}
			}
		},
		{
			"label": "Run frontend dev server",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"frontend",
				"run",
				"dev",
				"--",
				"--host"
			],
			"isBackground": true,
			"group": "build",
			"options": {
				"env": {
					"VITE_BACKEND_API_URL": "http://localhost:3200/api",
					"VITE_BOOKING_SERVICE_URL": "http://localhost:3204",
					"VITE_FLEET_SERVICE_URL": "http://localhost:3202",
					"VITE_TRIP_SERVICE_URL": "http://localhost:3203",
					"VITE_TRACKING_SERVICE_URL": "http://localhost:3205",
					"VITE_MOCK_GPS_SERVICE_URL": "http://localhost:3206",
					"VITE_ANALYTICS_SERVICE_URL": "http://localhost:3207",
					"VITE_ALERT_SERVICE_URL": "http://localhost:3208",
					"VITE_ML_SERVICE_URL": "http://localhost:8000"
				}
			}
		}
	]
}